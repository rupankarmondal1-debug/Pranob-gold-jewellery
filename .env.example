# Copy this file to .env and fill in your Supabase project's values
# (Settings → API in your Supabase project dashboard).
#
# Vite only exposes env vars to the browser if they're prefixed with
# VITE_ — that's a Vite requirement, not a Supabase one. The app reads
# them as SUPABASE_URL / SUPABASE_ANON_KEY internally (see src/lib/supabase.js).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
